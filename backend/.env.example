# =============================================================================
# TabAI Backend — Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values.
#   cp .env.example .env

# -----------------------------------------------------------------------------
# Database (Supabase PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres
# Set to true to skip SSL verification (dev only, never in production)
DATABASE_SSL_INSECURE=false

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# -----------------------------------------------------------------------------
# Cloudflare R2 (S3-compatible object storage)
# -----------------------------------------------------------------------------
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=tabai-audio

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
SECRET_KEY=run-openssl-rand-hex-32-to-generate
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3001

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
SENTRY_DSN=
